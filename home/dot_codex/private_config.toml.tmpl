model = "gpt-5.5"
model_reasoning_effort = "medium"
plan_mode_reasoning_effort = "xhigh"
add_dir = [ "~/.cache", "~/go/pkg/mod" ]

[profiles.browser]
sandbox_mode = "danger-full-access"
approval_policy = "on-request"

[plugins."gmail@openai-curated"]
enabled = true

[plugins."github@openai-curated"]
enabled = true

[notice]
hide_rate_limit_model_nudge = true

[apps.connector_76869538009648d5b282a4bb21c3d157.tools.github_create_pull_request]
approval_mode = "approve"

[apps.connector_692f171973888191b610a24ee6d1a512.tools.context7_resolve-library-id]
approval_mode = "approve"

[mcp_servers.pencil]
command = "/home/hayato/.pencil/mcp/visual_studio_code/out/mcp-server-linux-x64"
args = [ "--app", "visual_studio_code" ]

[tui.model_availability_nux]
"gpt-5.5" = 3

{{- $codex := get . "codex" | default dict }}
{{- $extractProjects := joinPath .chezmoi.sourceDir ".chezmoitemplates" "codex-projects.sh" }}
{{- $liveConfig := joinPath .chezmoi.homeDir ".codex" "config.toml" }}
{{- $localData := joinPath .chezmoi.sourceDir ".chezmoidata" "codex.local.toml" }}
{{- $projectsToml := output $extractProjects $liveConfig $localData | trimSuffix "\n" }}
{{- if $projectsToml }}

{{ $projectsToml -}}
{{- else }}
{{- $trustedProjects := get $codex "trusted_projects" | default dict }}
{{- range $project := keys $trustedProjects | sortAlpha }}
[projects.{{ $project | quote }}]
trust_level = {{ index $trustedProjects $project | quote }}

{{- end }}
{{- end }}
