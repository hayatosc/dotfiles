{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Bash(sudo *)",
      "Bash(rm *)",
      "Bash(chmod 777 *)",
      "Bash(npm install -g *)",
      "Bash(git config *)",
      "Bash(gh repo delete:*)"
    ],
    "ask": [
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git rebase *)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bun run ~/.claude/scripts/statusline.ts"
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "mcpServers": {
    "claude_ai_Notion": {
      "disabled": true
    },
    "claude_ai_Google_Calendar": {
      "disabled": true
    },
    "claude_ai_Gmail": {
      "disabled": true
    },
    "claude_ai_Context7": {
      "disabled": true
    }
  },
  "skipDangerousModePermissionPrompt": true
}
