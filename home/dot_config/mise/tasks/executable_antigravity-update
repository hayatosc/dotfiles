#!/usr/bin/env bun
// MISE description="Update google.com/antigravity-cli to the latest version and chezmoi apply"

import { $ } from "bun";
import { readFileSync, writeFileSync, existsSync } from "fs";
import { join } from "path";

console.log("Fetching the latest version of google.com/antigravity-cli...");

try {
  const response = await fetch("https://antigravity-cli-auto-updater-974169037036.us-central1.run.app/manifests/linux_amd64.json");
  if (!response.ok) {
    throw new Error(`HTTP error! status: ${response.status}`);
  }
  const json = (await response.json()) as { url: string };
  const downloadUrl = json.url;

  // Extract version from URL
  // e.g. https://storage.googleapis.com/antigravity-public/antigravity-cli/1.0.1-5826024320139264/linux-x64/cli_linux_x64.tar.gz
  const match = downloadUrl.match(/\/antigravity-cli\/([^/]+)\//);
  if (!match) {
    throw new Error(`Could not parse version from URL: ${downloadUrl}`);
  }
  const latestVersion = match[1];
  console.log(`Latest version: ${latestVersion}`);

  // Get chezmoi source directory
  const chezmoiSource = (await $`chezmoi source-path`.text()).trim();
  const configFile = join(chezmoiSource, "dot_config/mise/config.toml");

  if (!existsSync(configFile)) {
    throw new Error(`Config file not found at: ${configFile}`);
  }

  const content = readFileSync(configFile, "utf-8");
  const versionMatch = content.match(/"aqua:google.com\/antigravity-cli"\s*=\s*"([^"]+)"/);
  if (!versionMatch) {
    throw new Error("Could not find google.com/antigravity-cli in config.toml");
  }
  const currentVersion = versionMatch[1];

  if (currentVersion === latestVersion) {
    console.log(`antigravity-cli is already up to date (${currentVersion}).`);
    process.exit(0);
  }

  console.log(`Updating antigravity-cli: ${currentVersion} -> ${latestVersion}`);

  // Replace version in config.toml
  const updatedContent = content.replace(
    /"aqua:google.com\/antigravity-cli"\s*=\s*"[^"]+"/,
    `"aqua:google.com/antigravity-cli" = "${latestVersion}"`
  );
  writeFileSync(configFile, updatedContent, "utf-8");

  // Apply target config
  const home = process.env.HOME || "/home/hayato";
  const targetConfig = join(home, ".config/mise/config.toml");
  await $`chezmoi apply --force ${targetConfig}`;

  // Update lockfile
  console.log("Regenerating lockfile...");
  await $`mise lock --global aqua:google.com/antigravity-cli`;

  // Copy target lockfile back to chezmoi source
  const targetLock = join(home, ".config/mise/mise.lock");
  const sourceLock = join(chezmoiSource, "dot_config/mise/private_mise.lock");
  if (existsSync(targetLock)) {
    writeFileSync(sourceLock, readFileSync(targetLock));
  }

  // Final chezmoi apply
  await $`chezmoi apply --force`;

  console.log(`Successfully updated antigravity-cli to ${latestVersion} and applied changes via chezmoi.`);
} catch (error) {
  console.error("Error:", error);
  process.exit(1);
}
