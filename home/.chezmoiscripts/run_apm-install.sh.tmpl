#!/bin/bash
# Re-run whenever apm.yml or any self-authored skill under skills/ changes.
# apm.yml hash: {{ output "sh" "-c" (printf "sha256sum %s 2>/dev/null | cut -d' ' -f1" (joinPath .chezmoi.sourceDir ".." "skills" "apm.yml")) }}
# skills/ hash: {{ output "sh" "-c" (printf "find %s -mindepth 2 -maxdepth 3 -type f ! -path '*/.*' ! -path '*/apm_modules/*' 2>/dev/null | sort | xargs cat 2>/dev/null | sha256sum | cut -d' ' -f1" (joinPath .chezmoi.sourceDir ".." "skills")) }}

set -euo pipefail

if ! command -v apm >/dev/null 2>&1; then
    echo "apm CLI not installed. Run \`mise install\` first." >&2
    exit 0
fi

SKILLS_DIR="${HOME}/.local/share/chezmoi/skills"

# 1. Clean up old permanent symlink if it exists
if [ -L "${SKILLS_DIR}/.agents" ]; then
    rm "${SKILLS_DIR}/.agents"
fi

# 2. Set up temporary deployment and local source directories
TEMP_AGENTS_DIR="${SKILLS_DIR}/.agents"
TEMP_APM_DIR="${SKILLS_DIR}/.apm"
mkdir -p "${TEMP_AGENTS_DIR}"
mkdir -p "${TEMP_APM_DIR}/skills"

# 3. Temporarily symlink self-authored skills under .apm/skills
for dir in "${SKILLS_DIR}"/*/; do
    dir_name=$(basename "${dir}")
    if [[ "${dir_name}" != "apm_modules" && "${dir_name}" != "tests" && "${dir_name}" != "scratch" && "${dir_name}" != "."* ]]; then
        ln -nfs "../../${dir_name}" "${TEMP_APM_DIR}/skills/${dir_name}"
    fi
done

# 4. Install dependencies and compile skills locally into the temp .agents directory
cd "${SKILLS_DIR}"

# Back up config files to preserve mtime and generated_at if they don't actually change
cp -p apm.lock.yaml apm.lock.yaml.bak 2>/dev/null || true
cp -p apm.yml apm.yml.bak 2>/dev/null || true

echo "==> apm install (deploying skills temporarily to ${TEMP_AGENTS_DIR}/skills)"
apm install --target agent-skills

# Restore apm.lock.yaml if only generated_at changed (preventing unnecessary mtime / git diff updates)
if [ -f apm.lock.yaml.bak ]; then
    if [ -f apm.lock.yaml ]; then
        filter_lock() {
            grep -v '^[[:space:]]*generated_at:' "$1"
        }
        if diff <(filter_lock apm.lock.yaml) <(filter_lock apm.lock.yaml.bak) >/dev/null 2>&1; then
            mv apm.lock.yaml.bak apm.lock.yaml
        else
            rm apm.lock.yaml.bak
        fi
    else
        mv apm.lock.yaml.bak apm.lock.yaml
    fi
fi

# Restore apm.yml if it didn't change (preventing unnecessary mtime updates)
if [ -f apm.yml.bak ]; then
    if [ -f apm.yml ]; then
        if diff apm.yml apm.yml.bak >/dev/null 2>&1; then
            mv apm.yml.bak apm.yml
        else
            rm apm.yml.bak
        fi
    else
        mv apm.yml.bak apm.yml
    fi
fi

# 5. Sync the compiled skills to the actual destination (~/.agents/skills)
mkdir -p "${HOME}/.agents/skills"
if command -v rsync >/dev/null 2>&1; then
    rsync -a --delete "${TEMP_AGENTS_DIR}/skills/" "${HOME}/.agents/skills/"
else
    rm -rf "${HOME}/.agents/skills"
    cp -a "${TEMP_AGENTS_DIR}/skills" "${HOME}/.agents/"
fi

# 6. Clean up temporary directories
rm -rf "${TEMP_AGENTS_DIR}"
rm -rf "${TEMP_APM_DIR}"

echo "==> apm install completed and cleaned up temporary directories"

