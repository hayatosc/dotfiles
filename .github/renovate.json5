{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["config:recommended"],
  mode: "full",
  minimumReleaseAge: "3 days",
  platformAutomerge: false,
  mise: {
    managerFilePatterns: ["^home/dot_config/mise/config\\.toml$"],
  },
  // Mend ホスト型では mise config を trust できず Renovate 内の `mise lock` が
  // 失敗する (mise 子プロセスに CI / MISE_TRUSTED_CONFIG_PATHS を渡せないため)。
  // 代わりに mise.lock は専用ワークフロー (.github/workflows/mise-lock.yml) が
  // PR ブランチ上で再生成・コミットする。Renovate 自身には lock を触らせない。
  lockFileMaintenance: {
    enabled: false,
  },
  // Renovate 内の `mise lock` 失敗の artifact エラー通知 (PR コメント / Issue) を抑制する。
  suppressNotifications: ["artifactErrors"],
  packageRules: [
    {
      matchUpdateTypes: ["minor", "patch"],
      automerge: true,
    },
  ],
}
